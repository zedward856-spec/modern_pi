<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <touch deviceName="wch.cn USB2IIC_CTP_CONTROL (USB 1-1.3)" mapToOutput="HDMI-A-1" mouseEmulation="yes" />
  <theme>
    <font place="ActiveWindow">
      <name>Nunito Sans</name>
      <size>13</size>
      <weight>Medium</weight>
      <slant>Normal</slant>
    </font>
    <font place="InactiveWindow">
      <name>Nunito Sans</name>
      <size>13</size>
      <weight>Medium</weight>
      <slant>Normal</slant>
    </font>
    <name>PiXonyx</name>
  </theme>
  <keyboard>
    <keybind key="Super_L" onRelease="yes">
      <action name="Execute">
        <command>/home/sl01220/.local/bin/app-grid.py</command>
      </action>
    </keybind>
  </keyboard>
</openbox_config>
